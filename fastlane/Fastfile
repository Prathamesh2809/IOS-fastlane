# fastlane/Fastfile
require "base64"

default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do

    # ── 1. Decode & load the App Store Connect API key ──────────────────
    api_key_path = "/tmp/AuthKey.p8"
    File.write(api_key_path, Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_B64"]))

    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: api_key_path,
      in_house:     false
    )

    # ── 2. Bump build number to timestamp ───────────────────────────────
    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(
      build_number: build_number,
      xcodeproj:    "#{ENV['XCODE_PROJECT']}.xcodeproj"
    )

    # ── 3. Xcode automatic signing ───────────────────────────────────────
    update_code_signing_settings(
      use_automatic_signing: true,
      team_id:               ENV["TEAM_ID"],
      path:                  "#{ENV['XCODE_PROJECT']}.xcodeproj"
    )

    # ── 4. Build ─────────────────────────────────────────────────────────
    build_app(
      scheme:           ENV["XCODE_SCHEME"],
      xcodeproj:        "#{ENV['XCODE_PROJECT']}.xcodeproj",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "#{ENV['XCODE_SCHEME']}.ipa",
      clean:            true,
      export_options: {
        teamID:               ENV["TEAM_ID"],
        provisioningProfiles: {
          ENV["APP_IDENTIFIER"] => ""
        }
      }
    )

    # ── 5. Upload to TestFlight ───────────────────────────────────────────
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "./build/#{ENV['XCODE_SCHEME']}.ipa",
      skip_waiting_for_build_processing: true
    )

    UI.success "✅ Uploaded to TestFlight! Build: #{build_number}"

  ensure
    File.delete(api_key_path) if File.exist?(api_key_path)
  end

end