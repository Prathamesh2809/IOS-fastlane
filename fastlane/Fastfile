default_platform(:ios)

platform :ios do
  lane :beta do

    api_key_path = "/tmp/AuthKey.p8"

    File.write(
      api_key_path,
      Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_B64"])
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: api_key_path,
      in_house: false
    )

    if ENV["BUILD_NUMBER"] && !ENV["BUILD_NUMBER"].empty?
      build_number = ENV["BUILD_NUMBER"]
    else
      build_number = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: ENV["APP_IDENTIFIER"]
      ) + 1
    end

    increment_build_number(
      build_number: build_number,
      xcodeproj: "SampleApp.xcodeproj"
    )

    build_app(
      scheme: "SampleApp",
      project: "SampleApp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "SampleApp.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/SampleApp.ipa",
      skip_waiting_for_build_processing: true
    )

    UI.success("Uploaded to TestFlight! Build: #{build_number}")

  ensure
    File.delete(api_key_path) if File.exist?(api_key_path)
  end
end