require "shellwords"
require "securerandom"
require "tmpdir"

default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    # 1. Sanitize project path and ensure it scales correctly from the repo root
    project_name      = ENV["XCODE_PROJECT"].to_s.strip
    project_path      = File.expand_path(File.join("..", project_name), __dir__)
    
    keychain_name     = "ci_build_#{Time.now.to_i}.keychain"
    keychain_password = SecureRandom.hex(16)
    api_key_path      = "#{Dir.tmpdir}/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_KEY_ID']}.p8"
    cert_path         = "#{Dir.tmpdir}/dist_cert_#{Time.now.to_i}.p12"
    profile_path      = "#{Dir.tmpdir}/profile_#{Time.now.to_i}.mobileprovision"
    decoded_plist_path = "#{Dir.tmpdir}/profile_#{Time.now.to_i}_decoded.plist"

    begin
      # Guard Clause
      unless File.exist?(File.join(project_path, "project.pbxproj"))
        UI.user_error!("Cannot find a valid Xcode project file at: #{project_path}")
      end

      # 2. Setup Ephemeral Keychain
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )

      # 3. App Store Connect API key config
      File.write(api_key_path, Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_B64"]))
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_filepath: api_key_path,
        in_house: false
      )

      # 4. Import the distribution certificate with unlocked execution permissions
      File.write(cert_path, Base64.decode64(ENV["IOS_CERTIFICATE_P12"]))
      
      # We use a custom shell command to bypass UI prompts for the imported keys
      keychain_path_resolved = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
      sh("security import #{cert_path.shellescape} -k #{keychain_path_resolved.shellescape} -P #{ENV['IOS_CERTIFICATE_PASSWORD'].shellescape} -T /usr/bin/codesign -T /usr/bin/xcodebuild -A")

      # 5. Install and parse provisioning profile
      File.write(profile_path, Base64.decode64(ENV["IOS_PROVISIONING_PROFILE"]))
      install_provisioning_profile(path: profile_path)

      sh("security cms -D -i #{profile_path.shellescape} > #{decoded_plist_path.shellescape}")
      profile_name = sh("/usr/libexec/PlistBuddy -c 'Print :Name' #{decoded_plist_path.shellescape}").strip
      profile_uuid = sh("/usr/libexec/PlistBuddy -c 'Print :UUID' #{decoded_plist_path.shellescape}").strip

      UI.message("Installed provisioning profile: #{profile_name} (#{profile_uuid})")

      # 6. Resolve build number
      build_number =
        if ENV["BUILD_NUMBER"] && !ENV["BUILD_NUMBER"].empty?
          ENV["BUILD_NUMBER"].to_s.strip
        else
          (latest_testflight_build_number(
            api_key: api_key,
            app_identifier: ENV["APP_IDENTIFIER"]
          ) + 1).to_s
        end

      increment_build_number(
        build_number: build_number,
        xcodeproj: project_path
      )

      # 7. Force Manual Code Signing in the project structure
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id: ENV["TEAM_ID"],
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        targets: [ENV["XCODE_SCHEME"].to_s.strip],
        path: project_path
      )

      # 8. Build App
      build_app(
        scheme: ENV["XCODE_SCHEME"].to_s.strip,
        project: project_path,
        configuration: "Release",
        clean: true,
        output_directory: "./build",
        output_name: "#{ENV['XCODE_SCHEME'].to_s.strip}.ipa",
        export_method: "app-store",
        export_options: {
          method: "app-store",
          signingStyle: "manual",
          provisioningProfiles: {
            ENV["APP_IDENTIFIER"] => profile_name
          }
        },
        xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}"
      )

      # 9. Upload to TestFlight
      upload_to_testflight(
        api_key: api_key,
        ipa: "./build/#{ENV['XCODE_SCHEME'].to_s.strip}.ipa",
        skip_waiting_for_build_processing: true,
        distribute_external: false
      )

      UI.success("✅ Uploaded to TestFlight — build #{build_number}")

    ensure
      # Always clean up secrets and keys from the runner's disk
      [api_key_path, cert_path, profile_path, decoded_plist_path].each { |f| File.delete(f) if File.exist?(f) }
      delete_keychain(name: keychain_name) rescue nil
    end
  end
end