default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight with customizable versioning"
  lane :beta do |options|
    api_key_path = "/tmp/AuthKey.p8"

    File.write(
      api_key_path,
      Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_B64"])
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: api_key_path,
      in_house: false
    )

    # 1. 💡 Update Marketing Version (e.g., 1.2) if provided
    target_version = options[:version_number]
    if target_version.to_s.strip.empty?
      UI.message("No explicit version number provided. Keeping current Xcode project version.")
    else
      UI.message("Setting marketing version to: #{target_version}")
      increment_version_number(
        version_number: target_version.to_s,
        xcodeproj: "SampleApp.xcodeproj"
      )
    end

    # 2. Smart Build Number Resolution
    target_build_number = options[:build_number]
    if target_build_number.to_s.strip.empty?
      UI.message("No manual build number provided. Fetching latest from TestFlight...")
      begin
        current_online_build = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: ENV["APP_IDENTIFIER"]
        )
        target_build_number = current_online_build + 1
        UI.message("Found live build number: #{current_online_build}. Incrementing to: #{target_build_number}")
      rescue => e
        UI.important("Could not find any existing builds on TestFlight. Defaulting to 1. Error: #{e.message}")
        target_build_number = "1"
      end
    else
      UI.message("Using manually provided build number: #{target_build_number}")
    end

    # Apply resolved internal build number
    increment_build_number(
      build_number: target_build_number.to_s,
      xcodeproj: "SampleApp.xcodeproj"
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: ENV["TEAM_ID"],
      path: "SampleApp.xcodeproj"
    )

    build_app(
      scheme: "SampleApp",
      project: "SampleApp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "SampleApp.ipa",
      export_options: {
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/SampleApp.ipa",
      skip_waiting_for_build_processing: true
    )

    UI.success("🎉 Successfully deployed build to TestFlight!")

  ensure
    File.delete(api_key_path) if File.exist?(api_key_path)
  end
end