default_platform(:ios)

platform :ios do
  desc "Build and deploy app to TestFlight using GitHub Actions"
  lane :beta do
    # Clean up the secret value in case it includes the extension
    raw_project  = ENV["XCODE_PROJECT"].to_s.strip
    project_name = raw_project.gsub(/\.xcodeproj$/, "")
    
    # Map explicit base paths directly targeting your root layout
    root_dir     = File.expand_path("..", __dir__)
    project_path = File.join(root_dir, "#{project_name}.xcodeproj")
    
    cert_path     = File.expand_path("../dist_cert.p12", __dir__)
    profile_path  = File.expand_path("../profile.mobileprovision", __dir__)
    
    keychain_name = "github_action_ci"
    keychain_password = SecureRandom.hex(16)

    begin
      # 1. Verify project exists explicitly before proceeding
      unless Dir.exist?(project_path)
        UI.user_error!("Could not find your Xcode project directory at expected root: #{project_path}")
      end
      UI.message("🎯 Successfully targeting Xcode project at: #{project_path}")

      # 2. Create a secure, temporary keychain on the cloud runner
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )

      # 3. Force the runner to prioritize this keychain's pathing array
      keychain_db_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
      sh("security list-keychains -d user -s #{keychain_db_path.shellescape}")

      # 4. Import the p12 Certificate and unblock code signing access controls completely
      File.write(cert_path, Base64.decode64(ENV["IOS_CERTIFICATE_P12"]))
      sh("security import #{cert_path.shellescape} -k #{keychain_db_path.shellescape} -P #{ENV['IOS_CERTIFICATE_PASSWORD'].shellescape} -T /usr/bin/codesign -T /usr/bin/xcodebuild -A")
      
      # Unlock keychain partition access arrays for modern codesign requirements
      sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password.shellescape} #{keychain_db_path.shellescape} > /dev/null 2>&1")

      # 5. Install the mobile provision profile
      File.write(profile_path, Base64.decode64(ENV["IOS_PROVISIONING_PROFILE"]))
      sh("mkdir -p ~/Library/MobileDevice/Provisioning\\ Profiles")
      
      # Extract Provisioning Profile Metadata safely
      decoded_plist = "/tmp/profile_decoded.plist"
      sh("security cms -D -i #{profile_path.shellescape} > #{decoded_plist}")
      profile_uuid = sh("/usr/libexec/PlistBuddy -c 'Print :UUID' #{decoded_plist}").strip
      profile_name = sh("/usr/libexec/PlistBuddy -c 'Print :Name' #{decoded_plist}").strip
      sh("cp #{profile_path.shellescape} ~/Library/MobileDevice/Provisioning\\ Profiles/#{profile_uuid}.mobileprovision")

      # 6. Authenticate via App Store Connect API using direct string parsing
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_B64"])
      )

      # 7. Generate an incremental Timestamp Build Number
      build_number = Time.now.strftime("%Y%m%d%H%M")
      increment_build_number(
        build_number: build_number,
        xcodeproj: project_path
      )

      # 8. Apply Manual Signing Configurations natively to target structures
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id: ENV["TEAM_ID"],
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        targets: [ENV["XCODE_SCHEME"]],
        path: project_path
      )

      # 9. Archive and Package App Binary with explicit code-signing parameter rules
      build_app(
        scheme: ENV["XCODE_SCHEME"],
        project: project_path,
        configuration: "Release",
        clean: true,
        output_directory: File.join(root_dir, "build"),
        output_name: "#{ENV['XCODE_SCHEME']}.ipa",
        export_method: "app-store",
        export_options: {
          method: "app-store",
          signingStyle: "manual",
          provisioningProfiles: {
            ENV["APP_IDENTIFIER"] => profile_name
          }
        },
        # Pass variables targeting Keychain structural frameworks directly into xcodebuild
        xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} OTHER_CODE_SIGN_FLAGS=\"--keychain #{keychain_db_path.shellescape}\""
      )

      # 10. Push Binary Asset to Apple TestFlight
      upload_to_testflight(
        api_key: api_key,
        ipa: File.join(root_dir, "build", "#{ENV['XCODE_SCHEME']}.ipa"),
        skip_waiting_for_build_processing: true
      )

      UI.success("🚀 Successfully shipped version to TestFlight! Build: #{build_number}")

    ensure
      # Always wipe secrets and clean up the environment safely
      [cert_path, profile_path, decoded_plist].each { |f| File.delete(f) if f && File.exist?(f) }
      delete_keychain(name: keychain_name) rescue nil
    end
  end
end